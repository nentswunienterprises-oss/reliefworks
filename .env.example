# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Frontend Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co

# PayFast Configuration
PAYFAST_MERCHANT_ID=your_payfast_merchant_id
PAYFAST_MERCHANT_KEY=your_payfast_merchant_key
PAYFAST_PASSPHRASE=your_optional_payfast_passphrase
PAYFAST_SANDBOX=true
PAYFAST_RETURN_URL=http://localhost:5000/payments/success
PAYFAST_CANCEL_URL=http://localhost:5000/payments/cancelled
PAYFAST_NOTIFY_URL=http://localhost:5000/api/payfast/itn
PAYFAST_TRUSTED_IPS=196.33.227.0,197.97.145.0

# Optional explicit sandbox credentials (if different from live)
PAYFAST_SANDBOX_MERCHANT_ID=your_payfast_sandbox_merchant_id
PAYFAST_SANDBOX_MERCHANT_KEY=your_payfast_sandbox_merchant_key
PAYFAST_SANDBOX_PASSPHRASE=your_optional_payfast_sandbox_passphrase
PAYFAST_SANDBOX_RETURN_URL=http://localhost:5000/payments/success
PAYFAST_SANDBOX_CANCEL_URL=http://localhost:5000/payments/cancelled
PAYFAST_SANDBOX_NOTIFY_URL=http://localhost:5000/api/payfast/itn
PAYFAST_SUBSCRIPTION_NOTIFY_URL=http://localhost:5000/api/payfast/subscriptions/itn

# Transactional email (quote/invoice delivery)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=Relief Works <billing@yourdomain.com>
PUBLIC_APP_ORIGIN=http://localhost:5000
